# Copy this file to .env and fill in your Instagram credentials.
# The password is only used for the first login (and whenever the saved
# session expires) — after that a saved session in .session.json is reused.
IG_USERNAME=your_username
IG_PASSWORD=your_password

# Optional: post changes to a Discord channel on every check.
# Get the URL from: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL
# Leave empty to disable.
DISCORD_WEBHOOK_URL=

# Optional: lets you trigger a check from Discord with /check while `watch` is
# running (webhooks are send-only, so triggering needs a bot token).
# Create one at https://discord.com/developers/applications -> New Application
# -> Bot -> Reset Token. No privileged intents needed. Leave empty to disable.
DISCORD_BOT_TOKEN=

# Optional but recommended with the bot: your server's ID, so /check registers
# instantly (without it, global registration can take up to an hour).
# Discord: Settings -> Advanced -> Developer Mode, then right-click your
# server icon -> Copy Server ID.
DISCORD_GUILD_ID=
